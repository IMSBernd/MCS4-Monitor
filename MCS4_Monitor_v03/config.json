{
  "app_name": "MCS-4 Monitor",
  "mode": "simulator",
  "serial": {
    "port": "",
    "baudrate": 38400,
    "bytesize": 8,
    "parity": "O",
    "stopbits": 1,
    "timeout": 0.1
  },
  "packet": {
    "sync_byte": 255,
    "length": 8
  },
  "alarm": {
    "sensor_timeout_seconds": 3.0
  },
  "database": {
    "path": "mcs4_history.sqlite"
  }
}
